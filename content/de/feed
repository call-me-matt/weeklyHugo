<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0">
<channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Site.BaseURL }}de/feed.rss</link>
    <description>RSS-Feed für {{ .Site.Title }} auf Deutsch</description>
    <language>de-de</language>
    {{ range .Pages }}
    <item>
        <title>{{ .Title }}</title>
        <link>{{ .Permalink }}</link>
        <description>{{ .Summary }}</description>
        <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 GMT" }}</pubDate>
        <guid>{{ .Permalink }}</guid>
    </item>
    {{ end }}
</channel>
</rss>
